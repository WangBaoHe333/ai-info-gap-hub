# 本地开发：复制为 .env 后填写，禁止把 .env 提交到 Git
ADMIN_USERNAME=your-admin-name
ADMIN_PASSWORD=
APP_SECRET_KEY=
CORS_ORIGINS=http://localhost:5173
DEEPSEEK_API_KEY=

# 生产部署（复制本文件为 .env 后改下面这组）
# ADMIN_USERNAME 填你的用户名
# ADMIN_PASSWORD 填你的强密码
# APP_SECRET_KEY 用 python3 -c "import secrets; print(secrets.token_hex(32))" 生成
# CORS_ORIGINS 生产同源部署可留空
# SERVE_STATIC 可按需设置为 true 或 false
# DEEPSEEK_API_KEY 填你的 DeepSeek API Key
